# MongoDB connection string. MongoDB Atlas is recommended for Vercel.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/mini-commerce
MONGODB_DB=mini-commerce

# Used to sign the admin cookie. Generate a long random value in production.
JWT_SECRET=replace-with-a-long-random-secret

# First admin account. On the first successful login, the app creates this admin user.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
